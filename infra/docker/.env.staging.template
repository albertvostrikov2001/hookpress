# Staging template — copy to .env.staging and fill secrets via vault
APP_ENV=staging
NODE_ENV=production

POSTGRES_USER=hookpress
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hookpress
DATABASE_URL=postgresql+asyncpg://hookpress:CHANGE_ME@postgres:5432/hookpress

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

S3_ENDPOINT=https://s3.staging.example.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_MEDIA=hookpress-media-staging
S3_USE_SSL=true

API_SECRET_KEY=CHANGE_ME
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
CORS_ORIGINS=https://staging.hook.press
COOKIE_SECURE=true
DEV_LOGIN_ENABLED=false

NEXT_PUBLIC_API_URL=https://api.staging.hook.press
NEXT_PUBLIC_WS_URL=wss://api.staging.hook.press
NEXT_PUBLIC_PROMO_URL=https://promo.staging.hook.press

LLM_PROVIDER=mock
PAYMENT_PROVIDER=mock
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
