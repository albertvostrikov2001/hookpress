# Environment
NODE_ENV=development
APP_ENV=development

# PostgreSQL
POSTGRES_USER=hookpress
POSTGRES_PASSWORD=hookpress_dev
POSTGRES_DB=hookpress
DATABASE_URL=postgresql+asyncpg://hookpress:hookpress_dev@postgres:5432/hookpress

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=hookpress
S3_SECRET_KEY=hookpress_dev_secret
S3_BUCKET_MEDIA=hookpress-media
S3_REGION=us-east-1
S3_USE_SSL=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-openssl-rand
JWT_ACCESS_TTL_MINUTES=480
JWT_REFRESH_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COOKIE_SECURE=false
DEV_LOGIN_ENABLED=true

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_PROMO_URL=http://localhost:8081

# Promo (Go)
PROMO_PORT=8081
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=hookpress_promo

# Providers (mock by default)
LLM_PROVIDER=mock
AUDIO_PROVIDER=mock
PAYMENT_PROVIDER=mock
DISTRIBUTION_PROVIDER=mock

# OAuth (optional — leave empty for dev-login)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_YANDEX_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/yandex/callback
OAUTH_VK_CLIENT_ID=
OAUTH_VK_CLIENT_SECRET=
OAUTH_VK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/vk/callback
OAUTH_MOCK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/mock/callback

# Observability
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=false
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=hookpress-api

# Apple Sign-In (production — stub until keys configured)
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback

# Mail (mail profile)
SMTP_HOST=mailhog
SMTP_PORT=1025
